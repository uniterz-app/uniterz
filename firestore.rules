rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- 管理者（app/admin/* ・ games/teams 手動投入・お知らせ編集 等）
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "S6r5KyS9XcXds3Pm7koLzzELrvs2";
    }

    // ========================================================================
    // users
    // 参照: AuthProvider, SignupForm, OnboardingForm, Profile 設定, useProfile(handle),
    //       useUserLanguage, follow.ts, ContactForm, EventGate, ensureSlug 連携,
    //       users/{uid}/reads/*（お知らせ既読）, users/{uid}/groups/*（コミュAPIミラー）
    // ========================================================================
    match /users/{userId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && !('plan' in request.resource.data);

      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('handle' in resource.data) || !('handle' in request.resource.data)
            || request.resource.data.handle == resource.data.handle)
        && (!('username' in resource.data) || !('username' in request.resource.data)
            || request.resource.data.username == resource.data.username)
        && (!('slug' in resource.data) || !('slug' in request.resource.data)
            || request.resource.data.slug == resource.data.slug)
        && (!('counts' in request.resource.data)
            || request.resource.data.counts == resource.data.counts)
        && (!('plan' in resource.data) || !('plan' in request.resource.data)
            || request.resource.data.plan == resource.data.plan)
        && (!('createdAt' in resource.data) || !('createdAt' in request.resource.data)
            || request.resource.data.createdAt == resource.data.createdAt)
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 50))
        && (!('bio' in request.resource.data)
            || (request.resource.data.bio is string
                && request.resource.data.bio.size() <= 500))
        && (!('photoURL' in request.resource.data)
            || request.resource.data.photoURL is string)
        && (!('language' in request.resource.data)
            || request.resource.data.language == 'ja'
            || request.resource.data.language == 'en');

      allow delete: if request.auth != null && request.auth.uid == userId;

      match /followers/{followerId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == followerId;
        allow delete: if request.auth != null && request.auth.uid == followerId;
        allow update: if false;
      }

      match /following/{followingId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }

      match /reads/{announcementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /groups/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if false;
      }
    }

    // ========================================================================
    // slugs — ensureUserSlug（@handle 用）
    // ========================================================================
    match /slugs/{slugId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/slugs/$(slugId));
      allow update, delete: if false;
    }

    // ========================================================================
    // posts — 一覧・予想カード表示。本文の作成/更新/削除は API（Admin SDK）
    // likes/saves: PredictionPostCardV2
    // ========================================================================
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if false;

      match /likes/{likeUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == likeUid;
        allow delete: if request.auth != null && request.auth.uid == likeUid;
      }

      match /saves/{saveUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == saveUid;
        allow delete: if request.auth != null && request.auth.uid == saveUid;
      }
    }

    // ========================================================================
    // games / teams — ScheduleList, useGameDays, predict 画面, 結果UI 等（読取）
    // 管理画面 games-import / team-init は isAdmin
    // ========================================================================
    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========================================================================
    // お知らせ — 一覧・詳細は公開読取。管理画面から isAdmin が編集
    // ========================================================================
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========================================================================
    // お問い合わせ — ContactForm → submitContact（要ログイン）
    // ========================================================================
    match /contacts/{contactId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ========================================================================
    // バッジ — useMasterBadges / useUserBadges
    // 付与は Admin / Functions のみ
    // ========================================================================
    match /master_badges/{bid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_badges/{uid} {
      match /badges/{badgeId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ========================================================================
    // 統計 v2 — GamesPage, ProAnalysis, useUserDailyTrendV2 / Monthly*
    // 日次: クエリが日付範囲のみのため「ログイン済みなら読取可」（他ユーザーの日次が見える）
    //       厳密にする場合はクライアントを docId プレフィックス付きクエリ or API に変更
    // ========================================================================
    match /user_stats_v2/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /user_stats_v2_daily/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ProAnalysis 等で他ユーザーの {uid}_{month} も読むためログイン済みに開放
    match /user_stats_v2_monthly/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /monthly_global_stats_v2/{month} {
      allow read: if true;
      allow write: if false;
    }

    // ========================================================================
    // プレーオフ — lib/playoff-*, PlayoffBracketMarket, usePlayoffOfficialResults
    // ========================================================================
    match /playoffBracketMarket/{season} {
      allow read: if true;
      allow write: if false;
    }

    match /playoffResults/{season} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /playoffBrackets/{docId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.season is string
        && request.resource.data.bracket is map
        && docId == request.resource.data.season + '_' + request.auth.uid;

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && docId == resource.data.season + '_' + request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid
        && docId == resource.data.season + '_' + request.auth.uid;
    }

    // ========================================================================
    // コミュニティ — app/api/communities/* のみ（Admin SDK）。クライアント直叩き禁止
    // ========================================================================
    match /groups/{groupId} {
      allow read, write: if false;

      match /members/{memberId} {
        allow read, write: if false;
      }
    }

    // ========================================================================
    // analytics — functions/src/analytics/_core.ts → analytics/daily/stats/{dateKey}
    // 管理ダッシュボードは isAdmin のみ読取（クライアント SDK）
    // ========================================================================
    match /analytics/{analyticsDocId} {
      match /stats/{statId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }
  }
}
