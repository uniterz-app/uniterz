// Firestore Security Rules（アプリの参照元と整合）
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- 管理者（app/admin/* ・ games/teams 手動投入・お知らせ編集 等）
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "S6r5KyS9XcXds3Pm7koLzzELrvs2";
    }

    /** WC knockout bracket — sync with lib/wc/wc-knockout-config submissionClosesAtIso (M73 kickoff). */
    function wcBracketSubmissionOpenForSeason(season) {
      return season != "2025-26"
        || request.time < timestamp.date(2026, 6, 28) + duration.time(19, 0, 0, 0);
    }

    /** Playoff bracket submission deadline (request.time is UTC). 2026-04-19 02:00 JST = 2026-04-18 17:00 UTC. Sync with lib/playoff-bracket-config submissionClosesAtIso. */
    function playoffBracketSubmissionOpenForSeason(season) {
      return season != "2026"
        || request.time < timestamp.date(2026, 4, 18) + duration.time(17, 0, 0, 0);
    }

    /**
     * 表示名・bio からギャンブル関連語を拒否（Web API `lib/profile/profileGamblingTerms.ts` と同趣旨）。
     * 直接 Firestore を書くクライアント対策。英語は単語境界。
     */
    function profileTextGamblingFree(s) {
      return s is string
        && !(s.matches('.*ベット.*')
            || s.matches('.*ベッド.*')
            || s.matches('.*ベッティング.*')
            || s.matches('.*賭け.*')
            || s.matches('.*賭博.*')
            || s.matches('.*ギャンブル.*')
            || s.matches('(?i).*\\bbet\\b.*')
            || s.matches('(?i).*\\bbetting\\b.*')
            || s.matches('(?i).*\\bbets\\b.*')
            || s.matches('(?i).*\\bbetted\\b.*')
            || s.matches('(?i).*\\bbettor\\b.*'));
    }

    function isValidNotificationPrefs(p) {
      return p is map
        && (!('gameStart' in p) || p.gameStart is bool)
        && (!('gameFinal' in p) || p.gameFinal is bool)
        && (!('rankingUpdated' in p) || p.rankingUpdated is bool)
        && p.keys().hasOnly(['gameStart', 'gameFinal', 'rankingUpdated']);
    }

    // ========================================================================
    // users
    // 参照: AuthProvider, SignupForm, OnboardingForm, Profile 設定, useProfile(handle),
    //       useUserLanguage, ContactForm, EventGate, ensureSlug 連携,
    //       users/{uid}/reads/*（お知らせ既読）, users/{uid}/groups/*（コミュAPIミラー）
    // ========================================================================
    match /users/{userId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && !('plan' in request.resource.data)
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 50
                && profileTextGamblingFree(request.resource.data.displayName)))
        && (!('bio' in request.resource.data)
            || (request.resource.data.bio is string
                && request.resource.data.bio.size() <= 500
                && profileTextGamblingFree(request.resource.data.bio)));

      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('handle' in resource.data) || !('handle' in request.resource.data)
            || request.resource.data.handle == resource.data.handle)
        && (!('username' in resource.data) || !('username' in request.resource.data)
            || request.resource.data.username == resource.data.username)
        && (!('slug' in resource.data) || !('slug' in request.resource.data)
            || request.resource.data.slug == resource.data.slug)
        && (!('counts' in request.resource.data)
            || request.resource.data.counts == resource.data.counts)
        && (!('plan' in resource.data) || !('plan' in request.resource.data)
            || request.resource.data.plan == resource.data.plan)
        && (!('createdAt' in resource.data) || !('createdAt' in request.resource.data)
            || request.resource.data.createdAt == resource.data.createdAt)
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 50
                && profileTextGamblingFree(request.resource.data.displayName)))
        && (!('bio' in request.resource.data)
            || (request.resource.data.bio is string
                && request.resource.data.bio.size() <= 500
                && profileTextGamblingFree(request.resource.data.bio)))
        && (!('photoURL' in request.resource.data)
            || request.resource.data.photoURL == null
            || request.resource.data.photoURL is string)
        && (!('language' in request.resource.data)
            || request.resource.data.language == 'ja'
            || request.resource.data.language == 'en')
        && (!('notificationPrefs' in request.resource.data)
            || isValidNotificationPrefs(request.resource.data.notificationPrefs));

      allow delete: if request.auth != null && request.auth.uid == userId;

      match /reads/{announcementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /groups/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if false;
      }

      // Native プッシュトークン — クライアント直接書き込み可（API 経由推奨）
      match /pushTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // admin/badges から users/{uid}/badges/{id} へ付与
      match /badges/{badgeId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ========================================================================
    // slugs — ensureUserSlug（@handle 用）
    // ========================================================================
    match /slugs/{slugId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/slugs/$(slugId));
      allow update, delete: if false;
    }

    // ========================================================================
    // posts — 一覧・予想カード表示。本文の作成/更新/削除は API（Admin SDK）
    // likes/saves: PredictionPostCardV2
    // ========================================================================
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if false;

      match /likes/{likeUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == likeUid;
        allow delete: if request.auth != null && request.auth.uid == likeUid;
      }

      match /saves/{saveUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == saveUid;
        allow delete: if request.auth != null && request.auth.uid == saveUid;
      }
    }

    // ========================================================================
    // games / teams — ScheduleList, useGameDays, predict 画面, 結果UI 等（読取）
    // 管理画面 games-import / team-init は isAdmin
    // ========================================================================
    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========================================================================
    // お知らせ — 一覧・詳細は公開読取。管理画面から isAdmin が編集
    // ========================================================================
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========================================================================
    // お問い合わせ — ContactForm → submitContact（要ログイン）
    // ========================================================================
    match /contacts/{contactId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ========================================================================
    // バッジ — useMasterBadges / useUserBadges
    // 付与は Admin / Functions のみ
    // ========================================================================
    match /master_badges/{bid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_badges/{uid} {
      match /badges/{badgeId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ========================================================================
    // 統計 v2 — GamesPage, ProAnalysis, useUserStatsDailyTrend（プロフィール日次）, 月次リスト等
    // ========================================================================
    match /user_stats_v2/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /user_stats_v2_daily/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /user_stats_v2_monthly/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /monthly_global_stats_v2/{month} {
      allow read: if true;
      allow write: if false;
    }


    // cumulative_stats — Functions が集計。本人のみ読取（snapshotRanks / rankSnapshotHistory）
    match /cumulative_stats/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /rankSnapshotHistory/{dateKey} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ========================================================================
    // プレーオフ — lib/playoff-*, PlayoffBracketMarket, usePlayoffOfficialResults
    // ========================================================================
    match /playoffBracketMarket/{season} {
      allow read: if true;
      allow write: if false;
    }

    match /playoffResults/{season} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /playoffBrackets/{docId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.season is string
        && request.resource.data.bracket is map
        && docId == request.resource.data.season + '_' + request.auth.uid
        && playoffBracketSubmissionOpenForSeason(request.resource.data.season);

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && docId == resource.data.season + '_' + request.auth.uid
        && playoffBracketSubmissionOpenForSeason(resource.data.season);

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid
        && docId == resource.data.season + '_' + request.auth.uid
        && playoffBracketSubmissionOpenForSeason(resource.data.season);
    }

    // Chunked rescore queue — Cloud Functions のみ（Admin SDK）
    match /playoffBracketRescoreTasks/{taskId} {
      allow read, write: if false;
    }

    // ========================================================================
    // WC ノックアウトブラケット予想 — lib/wc/wc-bracket-firestore.ts
    // ========================================================================
    match /wcBracketResults/{season} {
      allow read: if true;
      allow write: if false;
    }

    match /wcKnockoutAdvancement/{season} {
      allow read: if true;
      allow write: if false;
    }

    match /wcBrackets/{docId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.season is string
        && request.resource.data.bracket is map
        && request.resource.data.isSubmitted == true
        && docId == request.resource.data.season + '_' + request.auth.uid
        && wcBracketSubmissionOpenForSeason(request.resource.data.season);

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && docId == resource.data.season + '_' + request.auth.uid
        && wcBracketSubmissionOpenForSeason(resource.data.season)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.season == resource.data.season
        && request.resource.data.isSubmitted == true
        && request.resource.data.bracket is map;

      allow delete: if false;
    }

    match /wcBracketRescoreTasks/{taskId} {
      allow read, write: if false;
    }

    // ========================================================================
    // コミュニティ — app/api/communities/* のみ（Admin SDK）。クライアント直叩き禁止
    // ========================================================================
    match /groups/{groupId} {
      allow read, write: if false;

      match /members/{memberId} {
        allow read, write: if false;
      }
    }

    // ========================================================================
    // analytics — functions/src/analytics/_core.ts → analytics/daily/stats/{dateKey}
    // ========================================================================
    match /analytics/{analyticsDocId} {
      match /stats/{statId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // ========================================================================
    // イベントログ（B1/J1/NBA）— クライアント create のみ
    // ========================================================================
    match /events_game/{eventId} {
      allow create: if
        (request.resource.data.type in [
          "click", "view", "predict",
          "click_card", "open_predictions", "open_predict"
        ])
        && request.resource.data.gameId is string
        && request.resource.data.gameId.size() > 0
        && request.resource.data.gameId.size() <= 128
        && request.resource.data.league in ["B1","J1","NBA"]
        && (!('ts' in request.resource.data) || request.resource.data.ts is number);
      allow read, update, delete: if false;
    }

    match /events_profile/{eventId} {
      allow create: if
        request.resource.data.type in ["profile_view","follow_click"]
        && request.resource.data.profileId is string
        && request.resource.data.profileId.size() > 0
        && request.resource.data.profileId.size() <= 128
        && (!('ts' in request.resource.data) || request.resource.data.ts is number);
      allow read, update, delete: if false;
    }

    // trend_cache（集計キャッシュ）
    match /trend_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
